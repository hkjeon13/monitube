# Copy this file to .env before running Docker Compose.
# .env is intentionally ignored by Git. Do not put production credentials here.

# Docker Compose / application mode
COMPOSE_PROJECT_NAME=monitube
APP_ENV=development
LOG_LEVEL=INFO
# The deployment script starts this many independent polling workers. Two is a
# conservative default: it interleaves video jobs without needlessly competing
# for the same YouTube project quota.
MONITUBE_WORKER_REPLICAS=2
MONITUBE_ANALYSIS_WORKER_REPLICAS=1

# PostgreSQL. DATABASE_URL is for commands run on the host; Compose injects
# DATABASE_URL_DOCKER into API and worker containers. All host ports bind to
# loopback by default; choose an unused *_PORT on a shared remote host.
POSTGRES_DB=monitube
POSTGRES_USER=monitube
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=postgresql://monitube:change-me-local-only@localhost:5432/monitube
DATABASE_URL_DOCKER=postgresql://monitube:change-me-local-only@postgres:5432/monitube

# PostgreSQL runtime tuning. Compose's checked-in defaults are deliberately
# small enough for local Docker. The remote deployment script adds the
# production candidates below only when a setting is absent from the remote
# .env, so an operator's explicit value always wins.
# POSTGRES_SHARED_PRELOAD_LIBRARIES=pg_stat_statements
# POSTGRES_SHARED_BUFFERS=4GB
# POSTGRES_EFFECTIVE_CACHE_SIZE=32GB
# POSTGRES_WORK_MEM=8MB
# POSTGRES_MAINTENANCE_WORK_MEM=512MB
# POSTGRES_AUTOVACUUM_WORK_MEM=256MB
# POSTGRES_MAX_CONNECTIONS=60
# POSTGRES_RANDOM_PAGE_COST=1.1
# POSTGRES_EFFECTIVE_IO_CONCURRENCY=200
# POSTGRES_MAX_WAL_SIZE=8GB
# POSTGRES_CHECKPOINT_COMPLETION_TARGET=0.9
# POSTGRES_WAL_COMPRESSION=on
# POSTGRES_TRACK_IO_TIMING=on
# POSTGRES_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=30s
# POSTGRES_LOG_MIN_DURATION_STATEMENT=500ms
# POSTGRES_LOG_TEMP_FILES=64MB
# POSTGRES_LOG_PARAMETER_MAX_LENGTH=0
# POSTGRES_LOG_PARAMETER_MAX_LENGTH_ON_ERROR=0
# POSTGRES_SHM_SIZE=1gb

# Redis. REDIS_URL is for host commands; containers receive REDIS_URL_DOCKER.
REDIS_BIND_ADDRESS=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0
# Redis stores only regenerable derived cache data in the current architecture.
REDIS_APPENDONLY=no
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Local S3-compatible object storage (MinIO) for analysis artifacts.
# These values are development-only root credentials and must not be reused.
MINIO_ROOT_USER=monitube-local
MINIO_ROOT_PASSWORD=change-me-minio-local-only
MINIO_BIND_ADDRESS=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_BIND_ADDRESS=127.0.0.1
MINIO_CONSOLE_PORT=9001
S3_ACCESS_KEY=monitube-local
S3_SECRET_KEY=change-me-minio-local-only
S3_BUCKET=monitube-local
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_ENDPOINT_URL=http://localhost:9000
S3_ENDPOINT_URL_DOCKER=http://minio:9000

# HTTP service addresses. Keep loopback bindings on a remote host and expose
# only Web/API through a reverse proxy when needed. Change host ports (for
# example API_PORT=18080 and WEB_PORT=13000) to avoid collisions.
API_BIND_ADDRESS=127.0.0.1
API_PORT=8000
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=3000
CORS_ORIGINS=http://localhost:3000
# Browser calls stay same-origin; Next proxies /api to the Docker API service.
NEXT_PUBLIC_API_BASE_URL=/api
MONITUBE_API_BASE_URL=http://api:8000
# Native Next development can use localhost; the Docker web service uses the
# internal Compose DNS target at build time.
MONITUBE_WEB_API_PROXY_TARGET=http://localhost:8000
MONITUBE_WEB_API_PROXY_TARGET_DOCKER=http://api:8000

# Per-process connection-pool budgets. With one API process, two collection
# workers, and one analysis worker, these stay below 80% of max_connections=60
# after reserving capacity for migrations and administration.
API_DB_POOL_MIN_SIZE=1
API_DB_POOL_MAX_SIZE=8
API_DB_POOL_TIMEOUT_SECONDS=5
WORKER_DB_POOL_MIN_SIZE=1
WORKER_DB_POOL_MAX_SIZE=2
WORKER_DB_POOL_TIMEOUT_SECONDS=10
ANALYSIS_DB_POOL_MIN_SIZE=1
ANALYSIS_DB_POOL_MAX_SIZE=2
ANALYSIS_DB_POOL_TIMEOUT_SECONDS=10
ANALYSIS_WORKER_MEMORY_LIMIT=1g
ANALYSIS_WORKER_CPU_LIMIT=1.0

# Server-managed YouTube Data API key. This template must remain blank. In
# production, use the server-only secret env file described in README—not this
# file, the browser, or user input. With no injected key, API/worker stay in
# fixture/no-op collection mode.
YOUTUBE_API_KEY=
YOUTUBE_API_KEYS=
YOUTUBE_API_KEY_ENCRYPTION_KEY=
YOUTUBE_KEY_REGISTRATION_TOKEN=

# Policy gate for future model-generated/derived analytics. It does not disable
# the core deterministic collection summary (counts, timestamps, top words).
# Keep it off until the required YouTube policy approval and product compliance
# review have been completed.
ENABLE_DERIVED_ANALYTICS=false

# Performance cutover flags are fail-closed. The remote deployment script can
# promote only the safe subset after schema/backfill validation. Rollup reads,
# Explore rollups, and Redis-derived cache remain off until reconciliation.
ENABLE_SOURCE_OVERVIEW_V2=false
ENABLE_TARGET_SUMMARY_WRITE=false
ENABLE_TARGET_SUMMARY_READ=false
ENABLE_ANALYSIS_WORKER=false
ENABLE_VIDEO_KEYSET_PAGINATION=false
ENABLE_COMMENT_BATCH_WRITE=false
ENABLE_COMMENT_ROLLUP_DUAL_WRITE=false
ENABLE_COMMENT_ROLLUP_READ=false
ENABLE_EXPLORE_ROLLUP=false
ENABLE_SEARCH_TRIGRAM=false
ENABLE_REDIS_DERIVED_CACHE=false
