# Copy this file to .env before running Docker Compose.
# .env is intentionally ignored by Git. Do not put production credentials here.

# Docker Compose / application mode
COMPOSE_PROJECT_NAME=monitube
APP_ENV=development
LOG_LEVEL=INFO

# PostgreSQL. DATABASE_URL is for commands run on the host; Compose injects
# DATABASE_URL_DOCKER into API and worker containers. All host ports bind to
# loopback by default; choose an unused *_PORT on a shared remote host.
POSTGRES_DB=monitube
POSTGRES_USER=monitube
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=postgresql://monitube:change-me-local-only@localhost:5432/monitube
DATABASE_URL_DOCKER=postgresql://monitube:change-me-local-only@postgres:5432/monitube

# Redis. REDIS_URL is for host commands; containers receive REDIS_URL_DOCKER.
REDIS_BIND_ADDRESS=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0

# Local S3-compatible object storage (MinIO) for analysis artifacts.
# These values are development-only root credentials and must not be reused.
MINIO_ROOT_USER=monitube-local
MINIO_ROOT_PASSWORD=change-me-minio-local-only
MINIO_BIND_ADDRESS=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_BIND_ADDRESS=127.0.0.1
MINIO_CONSOLE_PORT=9001
S3_ACCESS_KEY=monitube-local
S3_SECRET_KEY=change-me-minio-local-only
S3_BUCKET=monitube-local
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true
S3_ENDPOINT_URL=http://localhost:9000
S3_ENDPOINT_URL_DOCKER=http://minio:9000

# HTTP service addresses. Keep loopback bindings on a remote host and expose
# only Web/API through a reverse proxy when needed. Change host ports (for
# example API_PORT=18080 and WEB_PORT=13000) to avoid collisions.
API_BIND_ADDRESS=127.0.0.1
API_PORT=8000
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=3000
CORS_ORIGINS=http://localhost:3000
# Browser calls stay same-origin; Next proxies /api to the Docker API service.
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_API_REQUEST_TIMEOUT_MS=10000
MONITUBE_API_BASE_URL=http://api:8000
# Native Next development can use localhost; the Docker web service uses the
# internal Compose DNS target at build time.
MONITUBE_WEB_API_PROXY_TARGET=http://localhost:8000
MONITUBE_WEB_API_PROXY_TARGET_DOCKER=http://api:8000

# Server-managed YouTube Data API key. This template must remain blank. In
# production, use the server-only secret env file described in README—not this
# file, the browser, or user input. With no injected key, API/worker stay in
# fixture/no-op collection mode.
YOUTUBE_API_KEY=
YOUTUBE_API_KEYS=
YOUTUBE_API_KEY_ENCRYPTION_KEY=
YOUTUBE_KEY_REGISTRATION_TOKEN=

# Policy gate for future model-generated/derived analytics. It does not disable
# the core deterministic collection summary (counts, timestamps, top words).
# Keep it off until the required YouTube policy approval and product compliance
# review have been completed.
ENABLE_DERIVED_ANALYTICS=false
